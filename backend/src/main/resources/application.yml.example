spring:
  application:
    name: clinichnow
  datasource:
    url: jdbc:h2:file:./data/clinicnow
    driver-class-name: org.h2.Driver
    username: sa
    password:
  h2:
    console:
      enabled: true
      path: /h2-console
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
server:
  port: 8080
springdoc:
  api-docs:
    path: /v3/api-docs
  swagger-ui:
    path: /swagger-ui.html
jwt:
  secret: ${JWT_SECRET:change-this-to-a-secure-long-string}
  expiration: 86400000